# Copy to presence_ws/.env (same folder as docker-compose.yml). Do not commit secrets.

PRESENCE_WS_PORT=8765
PRESENCE_TENANT=default
PRESENCE_SERVICE_ID=presence-ws

# Optional: protect GET /health, /online, /metrics
# PRESENCE_X_API_TOKEN=change-me-read-secret

# Optional: POST /admin/kick*
# ADMIN_TOKEN=change-me-admin-secret

# Frappe verify (optional). For tests without Frappe even if URL/secret exist:
# FRAPPE_PRESENCE_VERIFY_ENABLED=false
# FRAPPE_PRESENCE_VERIFY_URL=http://frappe-backend:8000/api/pulse/internal/presence-ws-upgrade-verify
# FRAPPE_PRESENCE_VERIFY_SECRET=same-as-pulse_presence_auth_secret-in-site_config

NODE_INSTANCE_ID=presence-1
